<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GocGiaSu - Đăng ký & Đăng nhập</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../css/">
</head>
<body>

<div class="auth-page">
    <i class="bi bi-gear-fill decor-illustration" style="top: 20%; right: 48%; font-size: 5rem;"></i>
    <i class="bi bi-pencil-fill decor-illustration" style="top: 35%; left: 2%; font-size: 4rem; transform: rotate(-20deg);"></i>
    <i class="bi bi-book-half decor-illustration" style="bottom: 10%; left: 5%; font-size: 7rem;"></i>
    <i class="bi bi-journal-text decor-illustration" style="bottom: 5%; right: 2%; font-size: 6rem;"></i>

    <div class="container position-relative" style="z-index: 1;">
        <div class="row g-5 justify-content-center">
            
            <div class="col-lg-5 col-md-11">
                <div class="role-card h-100 shadow-lg">
                    <div class="auth-header">
                        <h2>VÀO LỚP NGAY</h2>
                    </div>
                    <div class="card-body p-4 p-xl-5">
                        <form>
                            <div class="auth-input-group">
                                <i class="bi bi-envelope-fill"></i>
                                <input type="text" class="form-control" placeholder="Tài khoản (Email/SĐT)">
                            </div>
                            <div class="auth-input-group">
                                <i class="bi bi-lock-fill"></i>
                                <input type="password" class="form-control" placeholder="Mật khẩu">
                            </div>
                            <div class="text-end mb-4">
                                <a href="#" class="text-teal small">[Quên mật khẩu?]</a>
                            </div>
                            <button type="submit" class="btn btn-auth">Đăng Nhập</button>
                            <div class="text-center mt-3">
                                <span class="small">Chưa có tài khoản? </span>
                                <a href="#" class="text-teal fw-bold small">[Tạo tài khoản học sinh]</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 col-md-11">
                <div class="role-card h-100 shadow-lg">
                    <div class="auth-header">
                        <h2>TẠO TÀI KHOẢN HỌC SINH</h2>
                    </div>
                    <div class="card-body p-4 p-xl-5">
                        <form>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="auth-input-group">
                                        <i class="bi bi-envelope-fill"></i>
                                        <input type="email" class="form-control" placeholder="Email hoặc SĐT">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-input-group">
                                        <i class="bi bi-person-fill"></i>
                                        <input type="text" class="form-control" placeholder="Họ tên">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-input-group">
                                        <i class="bi bi-lock-fill"></i>
                                        <input type="password" class="form-control" placeholder="Mật khẩu">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-input-group">
                                        <i class="bi bi-lock-fill"></i>
                                        <input type="password" class="form-control" placeholder="Nhập lại MK">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-check mb-4">
                                <input class="form-check-input" type="checkbox" id="terms">
                                <label class="form-check-label small" for="terms">
                                    Tôi đồng ý với <a href="#" class="text-teal fw-bold">Điều khoản</a>
                                </label>
                            </div>

                            <button type="submit" class="btn btn-auth">Tạo Tài Khoản Ngay</button>
                            <div class="text-center mt-3">
                                <span class="small">Đã có tài khoản? </span>
                                <a href="#" class="text-teal fw-bold small">[Đăng nhập ngay]</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>