<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - GocGiaSu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="../css/style.css">
</head>
<body class="auth-page-bg">

    <i class="bi bi-mortarboard-fill auth-decor" style="top: 10%; left: 5%; font-size: 10rem;"></i>
    <i class="bi bi-gear-fill auth-decor" style="top: 20%; right: 45%; font-size: 6rem;"></i>
    <i class="bi bi-journal-bookmark-fill auth-decor" style="bottom: 5%; right: 5%; font-size: 8rem;"></i>

   <div class="container position-relative" style="z-index: 1;">
    <div class="row g-5 justify-content-center align-items-stretch">
        
        <div class="col-lg-5 col-md-6">
            <div class="role-card h-100 shadow-lg">
                <div class="auth-card-header">
                    <h2>HỌC SINH ĐĂNG NHẬP</h2>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <span class="auth-subtitle"><i>Dành cho các bạn đang tìm kiếm gia sư</i></span>
                    <form>
                        <div class="auth-input-box">
                            <i class="bi bi-envelope-at-fill"></i>
                            <input type="text" class="form-control" placeholder="Email / Số điện thoại">
                        </div>
                        <div class="auth-input-box">
                            <i class="bi bi-lock-fill"></i>
                            <input type="password" class="form-control" placeholder="Mật khẩu">
                        </div>
                        
                        <div class="text-center mb-4">
                            <a href="#" class="text-teal small text-decoration-none">[Quên mật khẩu?]</a>
                        </div>

                        <button type="submit" class="btn-auth-wow w-100">VÀO LỚP NGAY</button>
                        
                        <div class="text-center mt-3">
                            <span class="small">Chưa có tài khoản? </span>
                            <a href="#" class="text-teal fw-bold small text-decoration-none">[Đăng ký tại đây]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 col-md-6">
            <div class="role-card h-100 shadow-lg">
                <div class="auth-card-header">
                    <h2>GIA SƯ ĐĂNG NHẬP</h2>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <span class="auth-subtitle"><i>Dành cho các thầy cô & sinh viên giảng dạy</i></span>
                    <form>
                        <div class="auth-input-box">
                            <i class="bi bi-person-badge-fill"></i>
                            <input type="text" class="form-control" placeholder="Mã gia sư / Email">
                        </div>
                        <div class="auth-input-box">
                            <i class="bi bi-shield-lock-fill"></i>
                            <input type="password" class="form-control" placeholder="Mật khẩu">
                        </div>
                        
                        <div class="text-center mb-4">
                            <a href="#" class="text-teal small text-decoration-none">[Quên mật khẩu?]</a>
                        </div>

                        <button type="submit" class="btn-auth-wow w-100">TRUY CẬP HỆ THỐNG</button>
                        
                        <div class="text-center mt-3">
                            <span class="small">Muốn làm Gia sư? </span>
                            <a href="#" class="text-teal fw-bold small text-decoration-none">[Đăng ký tại đây]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>